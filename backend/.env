# ╔══════════════════════════════════════════════════════════════════╗
# ║           ChaosProbeX — Environment Configuration               ║
# ╚══════════════════════════════════════════════════════════════════╝
#
# Copy this file to .env and fill in your credentials.
# Never commit .env to version control.
#
# cp .env.example .env

# ─── SERVER ────────────────────────────────────────────────────────
PORT=4000

# ─── SAFEDEP INTEGRATION ───────────────────────────────────────────
#
# Purpose: Scans your API's dependencies for known vulnerabilities,
#          malicious packages, and supply chain risks.
#
# How to get these:
#   1. Sign up at https://app.safedep.io  (free tier available)
#   2. Go to:  Settings → API Keys → Create New Key
#   3. Paste values below
#
SAFEDEP_API_KEY=SAFEDEP_CLOUD_API_KEY=sfd_27vw4dV-XZYDQIHmglVBoU_tWd5-QIcz2A9jQEqC6QcA-z6be1GklCFP
SAFEDEP_TENANT_ID=SAFEDEP_CLOUD_TENANT_DOMAIN=default-team.www-isro-gov-in.safedep.io

# ─── CONCIERGE MCP INTEGRATION ─────────────────────────────────────
#
# Purpose: Connects ChaosProbeX to your Concierge MCP server for
#          AI-powered post-test analysis via ChatGPT / Claude.
#
# How to get this:
#   1. Install: pip install concierge-sdk
#   2. Scaffold: concierge init --chatgpt
#   3. Deploy:   concierge deploy
#   4. Copy the printed URL:  https://<your-project>.getconcierge.app/mcp
#   5. Paste it below
#
#CONCIERGE_MCP_URL=https://your-project.getconcierge.app/mcp
#CONCIERGE_MCP_URL= https://getconcierge.app/login?session=12UCu-YR2eIZI3wNJcPuBw&mode=cli
CONCIERGE_MCP_URL=https://chaosprobex.getconcierge.app/mcp
# CONCIERGE_API_KEY=  # Only needed if your MCP server requires auth
